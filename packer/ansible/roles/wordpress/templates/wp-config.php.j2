<?php
/**
 * WordPress Configuration File
 *
 * All database credentials are read from environment variables at runtime.
 * These variables are injected by ECS from AWS Secrets Manager — no
 * credentials are hard-coded in this file or in the Docker image.
 *
 * Generated by Ansible — do not edit manually.
 */

// ---------------------------------------------------------------------------
// Database settings (injected via ECS task definition / Secrets Manager)
// ---------------------------------------------------------------------------

define( 'DB_HOST',     getenv('WORDPRESS_DB_HOST')     ?: 'localhost' );
define( 'DB_USER',     getenv('WORDPRESS_DB_USER')     ?: 'wordpress' );
define( 'DB_PASSWORD', getenv('WORDPRESS_DB_PASSWORD') ?: '' );
define( 'DB_NAME',     getenv('WORDPRESS_DB_NAME')     ?: 'wordpress' );
define( 'DB_CHARSET',  'utf8mb4' );
define( 'DB_COLLATE',  '' );

// ---------------------------------------------------------------------------
// Table prefix
// ---------------------------------------------------------------------------

$table_prefix = getenv('WORDPRESS_TABLE_PREFIX') ?: 'wp_';

// ---------------------------------------------------------------------------
// Authentication Keys and Salts
// These are generated fresh at image build time.
// For production, replace with values from https://api.wordpress.org/secret-key/1.1/salt/
// or inject via SSM Parameter Store / Secrets Manager.
// ---------------------------------------------------------------------------

define( 'AUTH_KEY',         '{{ wp_auth_key }}' );
define( 'SECURE_AUTH_KEY',  '{{ wp_secure_auth_key }}' );
define( 'LOGGED_IN_KEY',    '{{ wp_logged_in_key }}' );
define( 'NONCE_KEY',        '{{ wp_nonce_key }}' );
define( 'AUTH_SALT',        '{{ wp_auth_salt }}' );
define( 'SECURE_AUTH_SALT', '{{ wp_secure_auth_salt }}' );
define( 'LOGGED_IN_SALT',   '{{ wp_logged_in_salt }}' );
define( 'NONCE_SALT',       '{{ wp_nonce_salt }}' );

// ---------------------------------------------------------------------------
// WordPress URLs — read from environment so the image is portable
// ---------------------------------------------------------------------------

if ( getenv('WORDPRESS_SITE_URL') ) {
    define( 'WP_HOME',    getenv('WORDPRESS_SITE_URL') );
    define( 'WP_SITEURL', getenv('WORDPRESS_SITE_URL') );
}

// ---------------------------------------------------------------------------
// File system paths
// ---------------------------------------------------------------------------

define( 'ABSPATH', __DIR__ . '/' );

// ---------------------------------------------------------------------------
// Debugging — disable in production (controlled by env var)
// ---------------------------------------------------------------------------

$debug = filter_var( getenv('WORDPRESS_DEBUG') ?: 'false', FILTER_VALIDATE_BOOLEAN );
define( 'WP_DEBUG',         $debug );
define( 'WP_DEBUG_LOG',     $debug );
define( 'WP_DEBUG_DISPLAY', false );
@ini_set( 'display_errors', '0' );

// ---------------------------------------------------------------------------
// Performance
// ---------------------------------------------------------------------------

define( 'WP_CACHE',          true );
define( 'DISABLE_WP_CRON',   false );

// ---------------------------------------------------------------------------
// Security
// ---------------------------------------------------------------------------

define( 'DISALLOW_FILE_EDIT', true );  // Disable theme/plugin editor in admin
define( 'FORCE_SSL_ADMIN',    filter_var( getenv('WORDPRESS_FORCE_SSL') ?: 'false', FILTER_VALIDATE_BOOLEAN ) );

// ---------------------------------------------------------------------------
// Uploads — EFS mount point in production
// ---------------------------------------------------------------------------

define( 'UPLOADS', 'wp-content/uploads' );

// ---------------------------------------------------------------------------
// Bootstrap WordPress
// ---------------------------------------------------------------------------

require_once ABSPATH . 'wp-settings.php';
