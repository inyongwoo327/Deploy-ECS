; PHP configuration for WordPress on ECS
; Generated by Ansible

[PHP]
display_errors = Off [cite: 12]
display_startup_errors = Off [cite: 12]
error_reporting = E_ALL & ~E_DEPRECATED & ~E_STRICT [cite: 12]
log_errors = On [cite: 12]
error_log = /proc/self/fd/2 [cite: 12]

max_execution_time = 120 [cite: 13]
max_input_time = 120 [cite: 13]
memory_limit = 256M [cite: 13]

upload_max_filesize = 64M [cite: 13]
post_max_size = 64M [cite: 13]
max_file_uploads = 20 [cite: 13]

session.cookie_httponly = 1 [cite: 14]
session.cookie_secure = 1
session.use_strict_mode = 1 [cite: 14]

date.timezone = UTC [cite: 14]

[opcache]
opcache.enable = 1 [cite: 15]
opcache.memory_consumption = 128 [cite: 15]
opcache.interned_strings_buffer = 8 [cite: 15]
opcache.max_accelerated_files = 10000 [cite: 15]
opcache.revalidate_freq = 60 [cite: 15]
; opcache.fast_shutdown removed as it is deprecated in PHP 7.2+
opcache.enable_cli = 0 [cite: 15]